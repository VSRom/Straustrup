//==================================================================================
template<typename T>
struct S {

	S()
	{ }

	S(T value)
		: val(value)
	{ }

	T &read_val(T &v);
	const T &get() const;
	T &set(const T &value);
	friend std::ostream &operator<<(std::ostream &os, const S<T> &obj) { os << obj.val; return os; }
	friend std::ifstream &operator>>(std::ifstream &is, const S &obj) { is >> obj.val; return is; }
	
	const T &operator[](const T&) const { return val; };
	T &operator[](T&) { return val; };

private:
	T val;
};
//==================================================================================
template<typename T>
std::ostream &operator<<(std::ostream &os, const std::vector<T> &obj) {
	for (const T &a : obj)
		os << a << '\t';

	return os;
}
//==================================================================================
template<typename T>
const T &S<T>::get() const
{
	return val;
}
//==================================================================================
template<typename T>
T &S<T>::set(const T &value)
{
	val = value;
	return val;
}
//==================================================================================
template<typename T>
T &S<T>::read_val(T &v) {
	if constexpr (std::is_same_v<T, std::vector<int>>) { // Проверка является ли тип <T> - std::vector
		int elem;
		while (std::cin >> elem)
			v.push_back(elem);
	}
	else if constexpr (std::is_same_v<T, std::string>) {
		std::cin >> v;
	}
	else
		std::cin >> v;

			val = v;

	return val;
}
