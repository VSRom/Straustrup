#include <memory>
//=============================================================================================================================================
template<typename T>
class counted_ptr {
	T* ptr = nullptr;
	int* count;

public:
	counted_ptr(T* raw) : ptr(raw) { }

	counted_ptr(const counted_ptr& other) {		// Конструктор копирования
		ptr = new T * (*other.ptr);
	}

	T* operator=(const T* other) {

	}

	T* operator->() {
		return ptr;
	}

	T& operator*() {
		return *ptr;
	}

	~counted_ptr() {
		if (*count == 0 || count == nullptr) {
			delete ptr;
			delete count;
		}
	}

};
