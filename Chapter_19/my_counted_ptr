#include <iostream>
#include <memory>
//===============================================================================================================================
template<typename T>
class counted_ptr {
	T* ptr = nullptr;
	int* count = nullptr;

public:
	counted_ptr(T* raw) : ptr(raw) { count = new int(1); }

	counted_ptr(const counted_ptr& other) {		// Конструктор копирования
		count = other.count;
		if (other.count)
		(*count)++;
		ptr = other.ptr;
	}

	counted_ptr<T>& operator=(const counted_ptr<T>& other) {
		if (this == &other) return *this;	// Самоприсваивание

		int* temp_c = this->count;
		T* temp_p = this->ptr;

		this->count = other.count;
		this->ptr = other.ptr;

		if (other.count)
		(*other.count)++;

		if (temp_c) {
			(*temp_c)--;
			if (*temp_c == 0) {
				delete temp_p; delete temp_c;
			}
		}
		return *this;
	}

	T* operator->() {
		return ptr;
	}

	T& operator*() {
		return *ptr;
	}

	~counted_ptr() {
		if (count) {
			(*count)--;
			if (*count == 0) {
				delete ptr;
				delete count;
			}
		}
	}
};
