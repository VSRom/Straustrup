//=============================================================================================
template<class T>
class my_allocator {
public:
	T* allocate(int n) {					// выделяет память для n объектов типа T
		T* ptr = (T*)malloc(n * sizeof(T));
		if (ptr == nullptr) {
			std::cout << "EROOR malloc == nullptr\n";
			return 0;
		}
		return ptr;
	}

	void deallocate(T* p, int n) {		// освобождает память, занятую n объектами типа T, начиная с адреса p
		free(p);
		p = nullptr;
	}

	void construct(T* p, const T& v) {	// создает объект типа T со значением v по адресу p
		*p = v;
	}

	void destroy(T* p) {					// уничтожает объект T по адресу p
		p->~T();
	}
};
//=============================================================================================
template<class T, class A = my_allocator<T>>
class my_vector {

	A alloc;								// Для работы с памятью
	int sz;									// размер
	T* elem;								// указатель на элементы
	int space;								// размер + свободная память

public:
	my_vector() :sz(0), elem(0), space(0) {}

	T& operator[](int n) { return elem[n]; }	// доступ: возвращает ссылку
	const T& operator[](int n) const { return elem[n]; }

	int size() const { return sz; }			// текущий размер
	int capacity() const { return space; }

	void resize(int newsize, T def = T());
	void reserve(int newalloc);
	void push_back(const T& val);
	my_vector<T,A>& operator=(const my_vector<T,A>& a);
	
	~my_vector() {
		if (elem != nullptr) {
			for (int i = 0; i < sz; ++i) {

				alloc.destroy(&elem[i]);
			}
			alloc.deallocate(elem, space);
		}
	}

};
//=============================================================================================
template<class T, class A>
void my_vector<T, A>::resize(int newsize, T val)
{
	reserve(newsize);
	for (int i = sz; i < newsize; ++i) alloc.construct(&elem[i], val); // создаем
	for (int i = newsize; i < sz; ++i) alloc.destroy(&elem[i]); // уничтожаем
	sz = newsize;
}
//=============================================================================================
template<class T, class A>
void my_vector<T, A>::reserve(int newalloc)
{
	if (newalloc <= space) return;			// размер не уменьшается
	T* p = alloc.allocate(newalloc);		// выделяем новую память
	for (int i = 0; i < sz; ++i) alloc.construct(&p[i], elem[i]); // копируем
	for (int i = 0; i < sz; ++i) alloc.destroy(&elem[i]); // уничтожаем
	alloc.deallocate(elem, space);			// освобождаем старую память
	elem = p;
	space = newalloc;
}
//=============================================================================Ы================
template<class T, class A>
void my_vector<T, A>::push_back(const T& val)
{
	if (space == 0) reserve(8);					// начинаем с памяти для 8 элементов
	else if (sz == space) reserve(2 * space);	// выделяем больше памяти
	alloc.construct(&elem[sz], val);			// добавляем в конец значение val
	++sz;										// увеличиваем размер
}
//=============================================================================================
template<class T, class A>
my_vector<T,A>& my_vector<T,A>::operator=(const my_vector<T,A>& a)
{
	if (this == &a) return *this;		// самоприсваивание, ничего делать не надо

	// Уничтожаем все старые объекты

	for (int i = 0; i < sz; i++)
		alloc.destroy(&elem[i]);

	// Если памяти достаточно
		if (a.sz <= space) {
			for (int i = 0; i < a.sz; i++)
				alloc.construct(&elem[i], a.elem[i]);		// копируем
		}

	// Если памяти недостаточно
		else {
			alloc.deallocate(elem, space);
			elem = alloc.allocate(a.sz);
			for (int i = 0; i < a.sz; i++)
			alloc.construct(&elem[i], a.elem[i]);		// копируем
			space = a.sz;
		}

		sz = a.sz;
		return *this;
}
