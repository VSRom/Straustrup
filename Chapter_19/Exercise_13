#include <memory>
#include <string>
#include <iostream>
#include <algorithm>
//===============================================================================================================================
class tracer {
	std::string stroke = {};

public:
	tracer(std::string str) : stroke(std::move(str)) {
		std::cout << "[Created] == [" << stroke << "]\n";
	}
	tracer(const tracer& other) : stroke(other.stroke + "_copy") {
		std::cout << "[Copy created] == [" << stroke << "]\n";;	// Конструктор копирования

	}
	tracer operator=(const tracer& other) { // Конструктор присваивания
		if (this == &other) return *this;	// Самоприсваивание

		stroke = other.stroke + "_assigned";		// Присваивание 
		std::cout << "[Copy assigned] == [" << stroke << "]\n";
		return *this;						// Возврат текущего объекта
	}

	tracer& operator=(const tracer&& other) noexcept{		// Оператор присваивания перемещением
		stroke = std::move(other.stroke) + "_move_assigned";
		std::cout << "[Move assigned] == [" << stroke << "]\n";
		return *this;
	}

	tracer(tracer&& other) noexcept : stroke(std::move(other.stroke) + "_moved") {	// Конструктор перемещения
		std::cout << "[Move created] == [" << stroke << "]\n";
	}	

	~tracer() {
		std::cout << "[Destroy] == [" << stroke << "]\n";
	}
};
//===============================================================================================================================
tracer global("Global");
//===============================================================================================================================
class container {
	tracer member;
public:
	container() : member("Member") { }
};
