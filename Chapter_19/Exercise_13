class tracer {
	std::string stroke = {};

public:
	tracer(std::string str) : stroke(){
		std::getline(std::cin, stroke);
	}
	tracer(const tracer& other) {
		stroke = other.stroke;	// Конструктор копирования
		
	}
	tracer operator=(const tracer other) { // Конструктор присваивания
		if (this == &other) return *this;	// Самоприсваивание

		this->stroke = other.stroke;		// Присваивание 
		return *this;						// Возврат текущего объекта
	}

	tracer& operator=(const tracer&& other) noexcept {

	}	// Оператор присваивания перемещением

	tracer(tracer&& other) noexcept {

	}	// Конструктор перемещения
	~tracer() {
		std::cout << stroke << '\n';
	}
};
