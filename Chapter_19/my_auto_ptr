#include <iostream>
#include <memory>
//==================================================================================================================
template<typename T>
class my_auto_ptr {

	T* ptr;

public:
	my_auto_ptr(T* raw) : ptr(raw) { }		// Принимает сырой указатель и забирает владение

	T* operator->() {						// Находит методы класса
		return ptr;
	}

	T& operator*() {						// Получае доступ к объекту
		return *ptr;
	}

	~my_auto_ptr() {						// Память освободится когда указатель "умрёт"
		if (ptr != nullptr)
		delete ptr;
	}

	T* release() {
		T* new_ptr = ptr;
		ptr = nullptr;
		return new_ptr;
	}
};
//==================================================================================================================
int main() {

	return 0;
}
