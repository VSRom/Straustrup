#include <iostream>
#include <memory>
#include <vector>
#include <string>
//==================================================================================
template<typename T, typename U>
class Pair {
public:

	Pair(T k, U v)
		: key(k), val(v)
	{ }

	friend std::ostream& operator<<(std::ostream& os, const Pair<T, U>& obj) {
		os << obj.key << '\t' << obj.val; return os;
	}

private:
	T key;
	U val;
};

//==================================================================================
int main()
{
	Pair<int, std::string> hello = { 10, "good" };

	std::cout << hello;

	return 0;
}
