{
	God* mix_gods = new God("Zeus", "Greece", "Celestial chariot", "Lightning bolt");
	mix_gods = mix_gods->insert(new God("Athena", "Greece", "Owl", "Spear and Aegis"));
	mix_gods = mix_gods->insert(new God("Poseidon", "Greece", "Seashell chariot", "Trident"));
	mix_gods = mix_gods->insert(new God("Odin", "Norway", "Eight-legged horse Sleipnir", "Spear Gungnir"));
	mix_gods = mix_gods->insert(new God("Thor", "Norway", "Goat-drawn chariot", "Hammer Mjolnir"));
	mix_gods = mix_gods->insert(new God("Freya", "Norway", "Cat-drawn chariot", "Falcon cloak"));
	mix_gods = mix_gods->insert(new God("Ra", "Egypt", "Solar barque", "Staff and Ankh"));
	mix_gods = mix_gods->insert(new God("Anubis", "Egypt", "Desert sands", "Scales and Knife"));
	mix_gods = mix_gods->insert(new God("Horus", "Egypt", "Falcon", "Spear and Was-scepter"));
	
	God* egypt_gods = nullptr;
	God* norse_gods = nullptr;
	God* greek_gods = nullptr;
	
	while (mix_gods)
	{
		God* p1 = mix_gods->find("Egypt");
		if (p1 == mix_gods)
			mix_gods = p1->next();
	
		p1->erase();
	
		if (egypt_gods == nullptr)
			egypt_gods = egypt_gods->insert(p1);
		else
			egypt_gods = egypt_gods->add_ordered(p1);

		God* p2 = mix_gods->find("Norway");
		if (p2 == mix_gods)
			mix_gods = p2->next();
	
		p2->erase();
	
		if (norse_gods == nullptr)
			norse_gods = norse_gods->insert(p2);
		else
			norse_gods = norse_gods->add_ordered(p2);
	
	
		God* p3 = mix_gods->find("Greece");
		if (p3 == mix_gods)
			mix_gods = p3->next();
	
		p3->erase();
	
		if (greek_gods == nullptr)
			greek_gods = greek_gods->insert(p3);
		else
			greek_gods = greek_gods->add_ordered(p3);
	}
	
	print_all(egypt_gods);
	std::cout << "\n" << "\n";
	print_all(norse_gods);
	std::cout << "\n" << "\n";
	print_all(greek_gods);
	std::cout << "\n" << "\n";
}
