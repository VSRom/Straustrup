#include <string>
struct God;
//=======================================================================================================================
template <typename T>
class Link
{

public:
	Link(T* p = 0, T* s = 0)
		: prev(p), succ(s)
	{
	}

	T* advance(int n) const;			// удаляет n позиций из списка
	T* erase();						// удаляет данный объект из списка
	T* insert(Link<T>* n);				// вставляет n перед данным объектом
	T* add(Link<T>* n);					// вставляет n после данного объекта
	
	T* next() const {
		return succ;
	}

	T* previous() const {
		return prev;
	}

protected:
	T* prev;
	T* succ;
};
//=======================================================================================================================
struct God : public Link<God>
{
	God(std::string n, std::string m, std::string c, std::string g)
		: Link<God>(), name(n), mifologia(m), car(c), gun(g)

	{
	}

	God* add_ordered(God* n);
	God* find(const std::string& s);


	std::string name;
	std::string mifologia;
	std::string car;
	std::string gun;
};
//=======================================================================================================================
template <typename T>
T* Link<T>::advance(int n) const
// удаляет n позиций из списка если не находит, возвращает 0
// при положительном n переносит указатель на n узлов вперед, при отрицательном — на n узлов назад
{
	if (this == nullptr)
		return nullptr;

	Link<T>* p = static_cast<T*>(this);

	if (0 < n)
	{
		while (n--)
		{
			if (p->succ == 0) return nullptr;

			p = p->succ;
		}
	}
	else if (n < 0)
	{
		while (n++)
		{
			if (p->prev == 0) return nullptr;

			p = p->prev;
		}
	}
	else return this;
}
//=======================================================================================================================
template <typename T>
T* Link<T>::erase()
// удаляет узел *p(this) из списка; возвращает следующий за p(this)
{
	Link<T>* p = static_cast<Link<T>*>(this);

	if (!p) return nullptr;

	Link<T>* next_node = p->succ;
	Link<T>* prev_node = p->prev;

	if (p->succ) next_node->prev = p->prev;

	if (p->prev) prev_node->succ = p->succ;

	T* ptr = static_cast<T*>(this->succ);

	p->succ = nullptr;
	p->prev = nullptr;

	return ptr;
}
//=======================================================================================================================
template <typename T>
T* Link<T>::insert(Link<T>* n)
// вставляет n перед p; возвращает n
{
	Link<T>* p = static_cast<Link<T>*>(this);

	if (n == 0)
		return static_cast<T*>(p);						// ничего не вставляем

	if (p == nullptr)
		return static_cast<T*>(n);							// ничего не вставляем

	Link<T>* prev_node = prev;

	n->succ = static_cast<T*>(p);						// p следует за n

	if (prev)
		prev_node->succ = static_cast<T*>(n);

	n->prev = prev;

	prev = static_cast<T*>(n);								// n становится предшественником prev

	return static_cast<T*>(n);
}
//=======================================================================================================================
template <typename T>
T* Link<T>::add(Link<T>* n) // вставляет n после p; возвращает n
{
	Link<T>* p = static_cast<Link<T>*>(this);

	if (n == nullptr)
		return static_cast<T*>(p);

	if (p == nullptr)
		return static_cast<T*>(n);

	n->succ = p->succ;

	p->succ = static_cast<T*>(n);
	n->prev = static_cast<T*>(p);

	return static_cast<T*>(n);
}
//=======================================================================================================================
God* God::find(const std::string& s)
// находит s в списке; если не находит, возвращает 0
{
	God* current = this;
	while (current)
	{
		if (!current)
			return nullptr;

		if (current->mifologia == s)
			return current;

		current = current->succ;
	}
	return nullptr;
}
//=======================================================================================================================
God* God::add_ordered(God* n)
{
	if (!this)
		return n;

	God* head = this;
	God* current = this;

	while (current->prev)
		current = current->prev;

	while (current)
	{
		if (n->name < current->name) {
			current->insert(n);
			return n;
		}

		if (!current->succ) {
			current->add(n);
			return head;
		}

		current = current->succ;
	}

	return head;
}
//=======================================================================================================================
void print_all(God* g)
{
	std::cout << "{ ";

	while (g->previous())
		g = g->previous();

	while (g)
	{
		std::cout << g->name << ", " << g->mifologia << ", " << g->car << ", " << g->gun;

		if (g = g->next()) std::cout << " }\n{ ";
		else
			std::cout << " }";
	}
}
