#include <iostream>
#include <memory>
#include <fstream>
#include <vector>
//===============================================================================================================================
template<typename T>
class number {
public:
	number ()
	{ }

	number(T m)
		: member(m)
	{ }

	number<T> operator+(const number<T>& other) {
		return number<T>(this->member + other.member);
	}

	number<T>& operator+=(const number<T>& other) {
		this->member += other.member;
		return *this;
	}

	number<T> operator*(const number<T>& other) {
		return number<T>(this->member * other.member);
	}

	number<T> operator/(const number<T>& other) {
		return number<T>(this->member / other.member);
	}

	number<T> operator-(const number<T>& other) {
		return number<T>(this->member - other.member);
	}

	friend std::ostream& operator<<(std::ostream& os, const number<T>& eth) {
		return os << eth.member;
	}

	//	friend std::ostream& operator<<(std::ostream& os, const std::vector<number>& eth) {
	//		for (auto p : eth)
	//			os << p;
	//	
	//	}
	
	friend std::istream& operator>>(std::istream& is, number<T>& eth) {
		return is >> eth.member;
	}

	T get_member() const { return member; }

private:
	T member = 0;
};
//===============================================================================================================================
template<typename T, typename U>
T objects(const std::vector<number<T>>& val1, const std::vector<number<U>>& val2)
{
	if (val1.size() != val2.size())
		return 0;

	T resul = {};
	for (int i = 0; i < val1.size(); i++) {
		T res = val1[i].get_member() * val2[i].get_member();
		resul += res;
	}

	return resul;
}
