/*
	V	12. Напишите программу, принимающую на вход имя файла и выводящую слова по одному на каждой строке, предваряя их номером строки. Подсказка: используйте функцию getline().
*/
//========================================================================================================================================
#include <string>
#include <iostream>
#include <fstream>
//========================================================================================================================================
void error(std::string s, std::string &name)
{
	std::cerr << s << " " << name << '\n';
}
//========================================================================================================================================
void input_file()
{
	std::string inf = "name.txt";
	std::string letters = {};
	char symbol = '\0';
	int iter = 1;
	bool plus = false;
	std::string letter = {};

	std::ifstream ist(inf);

	if(!ist) error(" Unable to open output file ", inf);

	while (getline(ist, letters))
	{
		for (int i = 0; i < letters.size(); i++)
		{
			while (i < letters.size())
			{
				if (letters[i] == ' ')
					break;

				letter += letters[i];
				i++;
			}

			std::cout << iter << ": " << letter << '\n';
			letter = {};
		}
		iter++;
	}
}
//========================================================================================================================================
int main()
{
	input_file();

	return 0;
}
