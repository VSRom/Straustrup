//	    V	12. Измените порядок следования слов(определенных как строки, разделенные пробелами).
//            Например, строка Norwegian Blue parrot примет вид parrot Blue Norwegian.
//            Вы можете предположить, что все строки из файла могут поместиться в памяти одновременно.
//======================================================================================================
#include <iostream>
#include <fstream>
#include <vector>
//======================================================================================================
int main()
{
	std::string name = "12_Change_Str.txt";
	std::ifstream ist(name);

	std::string name2 = "12_Out_Change.txt";
	std::ofstream ost(name2);

	std::string interval;
	std::string interval_2;

	std::vector<std::string> result;
	std::vector<std::string> result_2;

	while (ist >> interval)
		result.push_back(interval);

	for (auto i = result.rbegin(); i != result.rend(); i++)
		result_2.push_back(*i);

	for (std::string stroke : result_2)
		ost << stroke << " ";

	return 0;
}
