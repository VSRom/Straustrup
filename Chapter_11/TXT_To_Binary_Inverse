//===============================================================================================================================
                                                              BINARY-TO-TXT
//===============================================================================================================================
int main()
{
    std::string name = "out_file_8";

    std::ifstream ifs(name.c_str(), std::ios_base::binary);

    if (!ifs) error("Don`t open file: ", name);


    std::string name_two = "out_file_8.txt";

    std::ofstream ofs(name_two.c_str(), std::ios_base::binary);

    if (!ofs) error("Don`t open file: ", name_two);

    std::vector<std::string> binary;
    std::string bit;
    std::string result;
    std::string interval;
    int i = 0;
    int g = 8;
    int m = 0;

    while (ifs >> bit)
        binary.push_back(bit);

    for (std::string a : binary)
    {
        for (int j = 0; j < a.size() / 8; j++)
        {
            for (m; m < g; m++, i++)
            {
                interval += a[i];
            }
            m = 0;
            std::bitset<8> bits(interval);

            result += static_cast<char>(bits.to_ulong());
            interval = {};

            if (i == a.size())
            {
                i = 0;
                ofs << result << " ";
                result = {};
            }
        }
    }
    

    return 0;
}
