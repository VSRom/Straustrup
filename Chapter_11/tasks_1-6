//  V	1. Напишите программу, вводящую текстовый файл и записывающую его содержимое в новый файл, используя нижний регистр.
//======================================================================================================================
int main()
{
	char c, d;
	std::string name_in = "in_file.txt";
	std::ifstream inf(name_in, std::ios_base::binary);

	std::string name_out = "out_file.txt";
	std::ofstream onf(name_out, std::ios_base::binary);

	while (inf.get(c))
	{
		d = tolower(c);
		onf << d;
	}

	return 0;
}
