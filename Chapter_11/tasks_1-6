	V	5. Напишите программу, заменяющую знаки пунктуации пробелами.
Например, строка “- don`t use the as-if rule.” принимает вид “dont use the asif rule”.
//======================================================================================================================
int main()
{
	std::string a, b;
	std::getline(std::cin, a);

	for (char c : a)		// Работаем посимвольно с вектором
	{
		if (std::ispunct(c))
		{
			b += ' ';
			continue;	// Пропускаем запись считанного символа и переходим к следующему
		}

		b += c;

	}

	std::cout << b << '\n';

	return 0;
}
