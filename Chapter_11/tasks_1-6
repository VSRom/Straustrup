//        Удивительно часто результат остается вполне читабельным; проверьте это на своих друзьях.
//======================================================================================================================
int main()
{
	char c, d;
	std::string name_in = "in_file.txt";
	std::ifstream inf(name_in, std::ios_base::binary);

	std::string name_out = "out_file_2.txt";
	std::ofstream onf(name_out, std::ios_base::binary);

	while (inf.get(c))
	{
		if (c == 'A' || c == 'a' || c == 'E' || c == 'e' || c == 'I' || c == 'i' || c == 'O' || c == 'o' || c == 'U' || c == 'u')
			continue;

		onf << c;
	}

	return 0;
}
