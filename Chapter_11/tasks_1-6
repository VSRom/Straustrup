	V	6. Модифицируйте программу из предыдущего упражнения, чтобы она заменяла сокращения don`t словами do not,
can`t — cannot и т.д.; дефисы внутри слов не трогайте (таким образом, мы получим строку “do not use the as-if rule”);
переведите все символы в нижний регистр.

- don`t use the as-if rule.
//======================================================================================================================
int main()
{
	int i = 0;
	std::string a, b;
	std::getline(std::cin, a);

	for (char c : a)		// Работаем посимвольно с вектором
	{
		if (c == '`')
		{
			if (b[i - 3] == 'd')
			{
				b.erase(b.size() - 1, 1);
			}
			b += " no";
			i += 2;
			continue;	// Пропускаем запись считанного символа и переходим к следующему
		}

		if (c == '-' || isspace(c))
		{
			if ((i - 1) > 0 && isalpha(b[i - 1]))
			{
				b += c;
				i++;
			}
			continue;
		}

		b += c;
		i++;
	}

	std::cout << b << '\n';

	return 0;
}
