int main()
{
	std::string a;
	std::getline(std::cin, a);

	for (char c : a)		// Работаем посимвольно с вектором
	{
		if (std::isspace(c))
			std::cout << c << " SPACE" << '\n';
		
		if (std::isalpha(c))
			std::cout << c << " ALPHA" << '\n';

		if (std::isdigit(c))
			std::cout << c << " DIGIT" << '\n';

		if (std::isxdigit(c))
			std::cout << c << " HEX-DIGIT" << '\n';
		
		if (std::ispunct(c))
			std::cout << c << " ISPUNCT" << '\n';

		if (std::isalnum(c))
			std::cout << c << " ISALNUM" << '\n';

		if (std::islower(c))
			std::cout << c << " ISLOWER" << '\n';

		if (std::isupper(c))
			std::cout << c << " ISUPPER" << '\n';

		if (std::isprint(c))
			std::cout << c << " ISPRINT" << '\n';

		if (std::isgraph(c))
			std::cout << c << " ISGRAPH" << '\n';

		if (std::iscntrl(c))
			std::cout << c << " ISCNTRL" << '\n';
	}

	return 0;
