#include <iostream>
#include <string>
#include <vector>
#include <fstream>
#include <algorithm>
//======================================================================================================================
int main()
{
	std::string name = "input_file.txt";
	std::ifstream ist(name);
	std::string b_stroke;
	
	std::string name_two = "outputfiledict.txt";
	std::ofstream ost(name_two);

	std::vector<std::string> stroke;
	std::vector<std::string> stroke_final;


	while(ist >> b_stroke)
	{
		stroke.push_back(b_stroke);
	}
	b_stroke = {};

	for (int i = 0, j = 0; i < stroke.size(); i++)
	{
		for (char c : stroke[i])
		{
			if (c == '`')
			{
				if (j >= 3 && stroke[i][j - 3] == 'd')
				{
					b_stroke.erase(b_stroke.size() - 1, 1);
				}

				b_stroke += " no";
				j += 2;
				continue;	// Пропускаем запись считанного символа и переходим к следующему
			}

			if (c == '-' || isspace(c))
			{
				if ((j - 1) > 0 && isalpha(b_stroke[j - 1]))
				{
					b_stroke += c;
					j++;
				}
				continue;
			}

			if (ispunct(c) && c != '+')
				continue;


			b_stroke += c;
			j++;
		}

		stroke_final.push_back(b_stroke);
		b_stroke = {};

		j = 0;
	}

	sort(stroke_final.begin(), stroke_final.end());

	for (int i = 0; i < stroke_final.size(); i++)
	{
		std::transform(stroke_final[i].begin(), stroke_final[i].end(), stroke_final[i].begin(), ::tolower);

		if (i == 0 || stroke_final[i] != stroke_final[i - 1])
			ost << stroke_final[i] << '\n';
	}


	return 0;
}
