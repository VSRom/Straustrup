#include <iostream>
#include <cstring>
//=========================================================================================================================
std::istream &read_word(std::istream &is, char *rev_orig, char *orig, int max)
{
    is.getline(rev_orig, max);
    int count = strlen(rev_orig);
    int count_ = count;
    char *ser = rev_orig;

    while (count != 0) {
        *orig = *ser;
        orig++, ser++; count--; }

    *orig = '\0';

    std::reverse(rev_orig, rev_orig + count_);

    return is;
}
//=========================================================================================================================
int main()
{
    const int max = 128;

    char *rev_orig = new char[max];
    char *orig = new char[max];

    while (read_word(std::cin, rev_orig, orig, max))
    {
        std::cout << orig << " is";
        if (strcmp(orig, rev_orig)) std::cout << " not";
        std::cout << " a palindrome\n";
    }

    delete[] orig;
    delete[] rev_orig;

    return 0;
}
