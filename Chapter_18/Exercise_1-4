#include <iostream>
//=========================================================================================================================
int strcmp(const char *s1, const char *s2)
{
	if (*s1 == '\0' && *s2 == '\0') return 0;
	if (*s1 == '\0') return -1;
	if (*s2 == '\0') return 1;

	while (*s1 != '\0' && *s2 != '\0')
	{
		if ((int)*s1 < (int)*s2) return -1;
		else if ((int)*s1 > (int)*s2) return 1;
		else { s1++; s2++; }
	}

	if (*s1 == '\0' && *s2 != '\0') return -1;
	if (*s2 == '\0' && *s1 != '\0') return 1;

	return 0;
}
