#include <iostream>
//=========================================================================================================================
char *strdup_(const char *cpy)
{
	const char *start = cpy;
	int count = 0;

	while (*cpy) { count++, cpy++; }

	char *ptr = new char[count+1];
	const char *s = start;
	char *ren = ptr;
	for ( int i = 0; i < count; i++, ptr++, s++)
	{
		*ptr = *s;

		std::cout << *ptr;
	}

	*ptr = '\0';

	return const_cast<char*>(ren);
}
//=========================================================================================================================
int main()
{
	char stroke[] = { 'H', 'e', 'l', 'l', 'o', '\0'};

	char *ptr = stroke;

	char stroke2[] = { 'B', 'u', 'k', 'a', ' ', 'H', 'e', 'l', 'l', 'o', ' ', 'G', 'U', 'D', 'H', 'e', 'l', 'l', 'o', '\0'};

	char *fi = stroke2;

	strdup_(ptr);
}
