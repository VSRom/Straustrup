char *findx(const char *s, const char *x)
{
	if (*x == '\0')
		return const_cast<char *>(s);

	while (*s != '\0') {
		const char *ptr = s;
		const char *ptr_ = x;

		while (*ptr != '\0' && *ptr_ != '\0' && *ptr == *ptr_) { ptr++; ptr_++; }

		if (*ptr_ == '\0') return const_cast<char *>(s);

		s++;
	}

	return nullptr;
}
