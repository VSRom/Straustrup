#include <iostream>
//=========================================================================================================================
char* cat_dog(const char* s1, const char* s2, const char* raz)
{
	const char *cat = s1; int count_cat = 0;
	const char *dog = s2; int count_dog = 0;
	const char *r = raz;  int count_raz = 0;

	while (*s1) { count_cat++; s1++; }
	while (*s2) { count_dog++; s2++; }
	while (*r)  { count_raz++;  r++; }

	int count = count_cat + count_dog + count_raz;

	char *ptr = new char[count + 2];
	char *ptr_rez = ptr;

	while (*cat != '\0') { *ptr = *cat; cat++; ptr++; }
	while (*raz != '\0') { *ptr = *raz; raz++; ptr++; }
	while (*dog != '\0') { *ptr = *dog; dog++; ptr++; }

	*ptr = '\0';

	return ptr_rez;
}
//=========================================================================================================================
int main()
{
	char cat[] = {'B', 'e', 's', 'h', 'a', 'n', 'i', 'n', '\0'};
	char dog[] = {'S', 'e', 'm', 'e', 'n', '\0' };
	char razdel[] = {'/', '=', '/', '\0' };

	char *c = cat;
	char *d = dog;
	char *r = razdel;

	char *result = cat_dog(c, d, r);

	char *del = result;

	std::cout << result;

	delete[] del;
}
