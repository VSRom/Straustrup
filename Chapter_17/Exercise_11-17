#include <iostream>
#include <iostream>
#include <vector>
//=======================================================================================================================
class Link
{

public:
	std::string value;

	Link(const std::string& v, Link* p = 0, Link* s = 0)
		:value(v), prev(p), succ(s)
	{
	}

	Link* insert(Link* n);				// вставляет n перед данным объектом

	Link* add(Link* n);					// вставляет n после данного объекта

	Link* erase();						// удаляет данный объект из списка

	Link* find(const std::string& s);		// находит s в списке

	Link* advance(int n) const;			// удаляет n позиций из списка


	Link* next() const
	{
		return succ;
	}

	Link* previous() const
	{
		return prev;
	}

private:

	Link* prev;
	Link* succ;

};
//=======================================================================================================================
Link* Link::advance(int n) const
// удаляет n позиций из списка если не находит, возвращает 0
// при положительном n переносит указатель на n узлов вперед, при отрицательном — на n узлов назад
{
	if (this == 0)
		return 0;

	if (0 < n)
	{
		while (n--)
		{
			if (this->succ == 0) return 0;

			this->succ;
		}
	}
	else if (n < 0)
	{
		while (n++)
		{
			if (this->prev == 0) return 0;

			this->prev;
		}
	}
	return 0;
}
//=======================================================================================================================
Link* Link::find(const std::string& s)
// находит s в списке; если не находит, возвращает 0
{
	while (this)
	{
		if (this->value == s) return this;

		this->succ;
	}
	return 0;
}
//=======================================================================================================================
Link* Link::erase()
// удаляет узел *p из списка; возвращает следующий за p
{
	if (this == 0)
		return 0;

	if (this->succ) this->succ->prev = this->prev;

	if (this->prev) this->prev->succ = this->succ;

	return this->succ;
}
//=======================================================================================================================
void print_all(Link* p)
{
	std::cout << "{ ";

	while (p)
	{
		std::cout << p->value;

		if (p = p->next()) std::cout << ", ";
	}

	std::cout << " }";
}
//=======================================================================================================================
Link* Link::insert(Link* n)
// вставляет n перед p; возвращает n
{
	if (n == 0)
		return this;						// ничего не вставляем

	if (this == 0)
		return n;							// ничего не вставляем

	n->succ = this;						// p следует за n

	if (prev)
		prev->succ = n;

	prev = n;								// succ(n) становится предшественником prev

	return n;
}
//=======================================================================================================================
Link* Link::add(Link* n) // вставляет n после p; возвращает n
{
	if (n == 0)
		return this;						// ничего не вставляем

	if (this == 0)
		return n;							// ничего не вставляем
	
	n->succ = this->succ;

	//	if (prev)
	//		this->succ = n;
	
	this->succ = n;

	n->prev = this;

	return n;
	// напоминает insert (см. упр. 11)
}
