
#include <iostream>
#include <fstream>
#include <vector>

//======================================================================================================================
void print_vector(std::ostream &os, std::vector<int> &a, int &n)
{
	for (int i = 0; i < n; i++)
		std::cout << "[" << i << "] == " << a[i] << '\n';
}
//======================================================================================================================
int main()
{
	int size = 20;
	std::vector<int> array;

	for (int i = 0, j = 100; i < size; i++, j++)
	{
		array.push_back(j);
	}

	print_vector(std::cout, array, size);
}
