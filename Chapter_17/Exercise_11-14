#include <iostream>
#include <iostream>
#include <vector>

//=======================================================================================================================
class Link
{

public:
	Link(Link *p = 0, Link *s = 0)
		: prev(p), succ(s)
	{
	}

	Link *insert(Link *n);				// вставляет n перед данным объектом

	Link *add(Link *n);					// вставляет n после данного объекта

	Link *erase();						// удаляет данный объект из списка

	Link *find(const std::string &s);		// находит s в списке

	Link *advance(int n) const;			// удаляет n позиций из списка

	Link *add_ordered(Link *n);			// размещает новый элемент с помощью оператора new в правильной лексикографической позиции

	Link *next() const
	{
		return succ;
	}

	Link *previous() const
	{
		return prev;
	}

private:
	Link *prev;
	Link *succ;
};
//=======================================================================================================================
struct God : public Link
{
	God(std::string n, std::string m, std::string c, std::string g)
		: Link(), name(n), mifologia(m), car(c), gun(g)

	{
	}

	std::string name;
	std::string mifologia;
	std::string car;
	std::string gun;
};
//=======================================================================================================================
Link *Link::advance(int n) const
// удаляет n позиций из списка если не находит, возвращает 0
// при положительном n переносит указатель на n узлов вперед, при отрицательном — на n узлов назад
{
	if (this == 0)
		return 0;

	Link *p = const_cast<Link *>(this);

	if (0 < n)
	{
		while (n--)
		{
			if (p->succ == 0) return 0;

			p = p->succ;
		}
	}
	else if (n < 0)
	{
		while (n++)
		{
			if (p->prev == 0) return 0;

			p = p->prev;
		}
	}
	return 0;
}
//=======================================================================================================================
Link *Link::find(const std::string &s)
// находит s в списке; если не находит, возвращает 0
{
	Link *p = this;

	while (p)
	{
		if (p == nullptr)
			return 0;

		if (static_cast<God *>(p)->mifologia == s)
			return p;

			p = p->succ;
	}
	return 0;
}
//=======================================================================================================================
Link *Link::erase()
// удаляет узел *p(this) из списка; возвращает следующий за p(this)
{
	Link *p = const_cast<Link *>(this);

	if (p == 0)
		return 0;

	if (p->succ) p->succ->prev = p->prev;

	if (p->prev) p->prev->succ = p->succ;

	p = this->succ;

	this->succ = 0;
	this->prev = 0;

	return p;
}
//=======================================================================================================================
Link *Link::insert(Link *n)
// вставляет n перед p; возвращает n
{
	if (n == 0)
		return this;						// ничего не вставляем

	if (this == 0)
		return n;							// ничего не вставляем

	n->succ = this;						// p следует за n

	if (prev)
		prev->succ = n;

	n->prev = prev;

	prev = n;								// succ(n) становится предшественником prev

	return n;
}
//=======================================================================================================================
Link *Link::add(Link *n) // вставляет n после p; возвращает n
{
	if (n == 0)
		return this;

	if (this == 0)
		return n;

	n->succ = this->succ;

	this->succ = n;
	n->prev = this;

	return n;
}
//=======================================================================================================================
Link *Link::add_ordered(Link *n)
{
	Link *p = static_cast<God *>(this);

	while (p)
	{
		if (static_cast<God *>(n)->name < static_cast<God *>(p)->name)
		{
			p = p->succ;

			if (p == nullptr)
				return add(n);

			if (!(static_cast<God *>(n)->name > static_cast<God *>(p)->name))
				return insert(n);
		}

		if (p->succ == nullptr)
			return add(n);
	}

	return 0;
}
//=======================================================================================================================
void print_all(Link *g)
{
	std::cout << "{ ";

		while (g->previous())
			g = g->previous();

	while (g)
	{
		std::cout << static_cast<God *>(g)->name << ", " << static_cast<God *>(g)->mifologia << ", " << static_cast<God *>(g)->car << ", " << static_cast<God *>(g)->gun;

		if (g = g->next()) std::cout << " }\n{ ";
		else
			std::cout << " }";
	}
}
