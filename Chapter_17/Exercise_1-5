char *findx(const char *s, const char *x)
{
    int g = 0;

    const char *ptr = nullptr;

    if (x[0] == '\0')
        return const_cast<char *>(s);

    for (int i = 0, j = 0; s[i] != '\0'; i++)
    {
        if (x[j] == '\0') [[unlikely]]
        {
            ptr = &s[i];
            return const_cast<char *>(ptr);
        }

        if (s[i] == x[j])
        {
            g = i;

            for (; x[j] != '\0' && s[g] != '\0'; j++, g++)
            {
                if (s[g] != x[j]) [[unlikely]]
                {
                    j = 0;
                    break;
                }
                if (x[j + 1] == '\0')
                {
                    ptr = &s[i];
                    return const_cast<char *>(ptr);
                }
            }
        }
    }

    return nullptr;
}
