#include <iostream>
#include <fstream>

//======================================================================================================================
void print_array10(std::ostream &os, int *a)
{
	for (int i = 0; i < 10; i++)
		std::cout << "[" << i << "] == " << a[i] << '\n';
}
//======================================================================================================================
int main()
{
	int size = 10;
	int *array = new int[size];

	for (int i = 0; i < size; i++)
		array[i] = i;

	print_array10(std::cout, array);
	

		delete[] array;
}
