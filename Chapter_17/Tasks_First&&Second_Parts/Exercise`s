#include <iostream>
#include <tuple>
//======================================================================================================================
int main()
{

    std::tuple<int, double, bool> mt = { 12, 12.0, "false" };
    std::cout << &std::get<int>(mt) << '\n' << &std::get<double>(mt) << '\n' << &std::get<bool>(mt) << '\n';
    return 0;
}
